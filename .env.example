# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Banco de dados MySQL/TiDB (Manus injecta automaticamente) ─
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quantia

# ─── Autenticação JWT ─────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# ─── Manus OAuth (Manus injecta automaticamente) ─────────────
MANUS_OAUTH_URL=https://auth.manus.im
MANUS_CLIENT_ID=your_manus_client_id
MANUS_CLIENT_SECRET=your_manus_client_secret

# ─── URL da aplicação ─────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Armazenamento S3 (Manus injecta automaticamente) ────────
S3_BUCKET=quantia
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
